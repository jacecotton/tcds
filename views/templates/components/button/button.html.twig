{% extends "templates/components/component/component.html.twig" %}

{% set component_name = "Button" %}

{% set required_props = [label] %}

{% if link %}
  {% set root_element = "a" %}
{% else %}
  {% set root_element = "button" %}
{% endif %}

{% block root_attributes %}
  {% if "icon-only" in modifiers %}
    aria-label="{{ label }}"
    title="{{ label }}"
  {% endif %}

  {% if link %}
    href="{{ link }}"
  {% endif %}
  {% if onclick %}
    onclick="{{ onclick }}"
  {% endif %}
  {% if type %}
    type="{{ type }}"
  {% endif %}

  {% if controls %}
    aria-controls="{{ controls }}"
  {% endif %}
{% endblock %}

{% block inner_content %}
  {% if icon %}
    {{ include("templates/components/icon/icon.html.twig", {
      icon: icon,
      custom_classes: ["Button__icon"],
    }, with_context = false) }}
  {% endif %}

  {% if "icon-only" not in modifiers %}
    {{ label|raw }}
  {% endif %}
{% endblock %}